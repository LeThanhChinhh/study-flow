# Local PostgreSQL container
POSTGRES_USER=studyflow_user
POSTGRES_PASSWORD=secretpassword
POSTGRES_DB=studyflow_db
POSTGRES_PORT=5433

# Spring Boot local profile
SPRING_PROFILES_ACTIVE=local
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/studyflow_db
SPRING_DATASOURCE_USERNAME=studyflow_user
SPRING_DATASOURCE_PASSWORD=secretpassword
JWT_SECRET=replace-with-a-secret-of-at-least-32-characters
JWT_EXPIRATION_MS=86400000
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# AI
STUDYFLOW_AI_PLANNING_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_TIMEOUT_SECONDS=60

# Frontend
VITE_API_BASE_URL=http://localhost:8080
